# Thai Meet local mock-first environment.
NODE_ENV=development
API_PORT=3000
DATABASE_URL=postgresql://thai_meet:thai_meet@localhost:5432/thai_meet
REDIS_URL=redis://localhost:6379

# Gate 0 provider defaults. Real credentials are not required for local smoke.
AUTH_MODE=mock
CONTACT_PROVIDER_LINE_ENABLED=true
CONTACT_PROVIDER_FACEBOOK_ENABLED=false
LINE_PROVIDER_MODE=mock
FACEBOOK_PROVIDER_MODE=mock
ADMOB_MODE=mock
FCM_MODE=mock
OBJECT_STORAGE_MODE=local
PERSISTENCE_MODE=fixture

# Gate 0 production readiness contract. Real secret values must be injected by CI/runtime.
AUTH_PROVIDER_JWKS_URL=https://auth.example.invalid/.well-known/jwks.json
AUTH_PROVIDER_ISSUER=https://auth.example.invalid/
AUTH_PROVIDER_AUDIENCE=thai-meet-api
LINE_CHANNEL_ID=0000000000
LINE_CHANNEL_SECRET=replace-in-secret-store
AWS_REGION=ap-southeast-1
S3_BUCKET_PUBLIC_ASSETS=thai-meet-public-assets

# Production overrides:
# AUTH_MODE=production
# LINE_PROVIDER_MODE=production
# OBJECT_STORAGE_MODE=s3
# PERSISTENCE_MODE=database

# Gate 0 feature flag defaults. Risky or broader-scope behavior starts off.
PUBLIC_ID_REGEN_ENABLED=true
PUBLIC_ID_ARCHIVE_ENABLED=true
CONTACT_SHARE_WARNING_ONCE=true
REQUIRE_MATCH_TO_CHAT=false
REQUIRE_MATCH_TO_SHARE_CONTACT=false
DISCOVER_NATIVE_ADS_ENABLED=false
CHAT_DETAIL_ADS_ENABLED=false
REWARDED_ADS_ENABLED=false
STRICT_MODERATION_ENABLED=false
ADMIN_WEB_ENABLED=false
AUTO_HIDE_REPORTED_PROFILE_THRESHOLD=5
AUTO_SUSPEND_REPORT_THRESHOLD=10

# Local-only fixture values. Do not use real contact values here.
MOCK_LINE_CONTACT=mock-line-contact
MOCK_FACEBOOK_URL=https://facebook.example.invalid/mock-contact
