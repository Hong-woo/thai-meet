{
  "name": "thai-meet",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node apps/api/src/server.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:doctor": "node scripts/smoke.mjs --doctor",
    "smoke:metrics": "node scripts/smoke-metrics.mjs",
    "gate0:status": "node scripts/gate0-status.mjs",
    "gate0:status:test": "node scripts/check-gate0-status.mjs",
    "production:check": "node scripts/check-production-readiness.mjs",
    "api:service:test": "node scripts/check-gate0-service.mjs",
    "api:fixture-store:test": "node scripts/check-gate0-fixture-store.mjs",
    "test": "node scripts/check-mobile-routes.mjs && npm run mobile:flutter:analyze && npm run mobile:flutter:test && node wireframes/qa-check.mjs && node scripts/check-contracts.mjs && node scripts/check-api-runtime.mjs && npm run api:fixture-store:test && npm run api:service:test && node scripts/check-trust-loop.mjs && node scripts/check-privacy-leaks.mjs && node scripts/check-dx-metrics.mjs && npm run gate0:status:test && npm run mobile:device:result:test && node scripts/check-env-matrix.mjs && node scripts/check-error-envelope.mjs && npm run db:check:test && npm run not-scaffolded:test && node scripts/check-feature-flags.mjs && node scripts/check-reward-ledger.mjs && npm run production:check",
    "api:dev": "node apps/api/src/server.mjs",
    "api:check": "node scripts/check-api-runtime.mjs",
    "api:openapi": "node scripts/generate-openapi.mjs",
    "api-client:generate": "node scripts/generate-dart-client.mjs",
    "mobile:mock-data:generate": "node scripts/generate-mobile-mock-data.mjs",
    "mobile:flutter:analyze": "cd apps/mobile && flutter analyze",
    "mobile:flutter:test": "cd apps/mobile && flutter test",
    "mobile:flutter:build:android": "cd apps/mobile && flutter build apk --debug",
    "mobile:flutter:build:web": "cd apps/mobile && flutter build web",
    "mobile:device:smoke": "node scripts/mobile-device-smoke.mjs",
    "mobile:device:result": "node scripts/read-mobile-device-smoke-result.mjs",
    "mobile:device:result:test": "node scripts/check-mobile-device-result-reader.mjs",
    "env:check": "node scripts/check-env-matrix.mjs",
    "errors:check": "node scripts/check-error-envelope.mjs",
    "flags:check": "node scripts/check-feature-flags.mjs",
    "privacy:test": "node scripts/check-privacy-leaks.mjs",
    "rewards:check": "node scripts/check-reward-ledger.mjs",
    "db:check": "node scripts/check-db-matrix.mjs",
    "db:check:test": "node scripts/check-db-matrix.mjs && node scripts/check-db-matrix-command.mjs",
    "not-scaffolded:test": "node scripts/check-not-scaffolded.mjs",
    "db:migrate": "node scripts/not-scaffolded.mjs db:migrate \"Prisma schema/migrations are not scaffolded yet. See docs/dev/GATE1_PERSISTENCE.md.\" docs/dev/GATE1_PERSISTENCE.md",
    "db:seed": "node scripts/seed-gate0-fixtures.mjs",
    "mobile:run": "cd apps/mobile && flutter run",
    "mobile:preview:web": "cd apps/mobile && flutter run -d web-server --web-hostname=127.0.0.1 --web-port=5370",
    "mobile:test:routes": "node scripts/check-mobile-routes.mjs",
    "wireframes:check": "node wireframes/qa-check.mjs"
  },
  "devDependencies": {}
}
